{
  "name": "album2tube",
  "version": "1.0.0",
  "description": "Turn an album folder into YouTube-ready videos.",
  "type": "module",
  "scripts": {
    "dev": "bun src/cli.ts",
    "check": "tsc --noEmit",
    "build:linux-x64": "bun build --compile --minify --target=bun-linux-x64 src/cli.ts --outfile dist/album2tube-linux-x64",
    "build:linux-arm64": "bun build --compile --minify --target=bun-linux-arm64 src/cli.ts --outfile dist/album2tube-linux-arm64",
    "build:macos-x64": "bun build --compile --minify --target=bun-darwin-x64 src/cli.ts --outfile dist/album2tube-macos-x64",
    "build:macos-arm64": "bun build --compile --minify --target=bun-darwin-arm64 src/cli.ts --outfile dist/album2tube-macos-arm64",
    "build:windows-x64": "bun build --compile --minify --target=bun-windows-x64 src/cli.ts --outfile dist/album2tube-windows-x64.exe",
    "build:all": "bun run build:linux-x64 && bun run build:linux-arm64 && bun run build:macos-x64 && bun run build:macos-arm64 && bun run build:windows-x64"
  },
  "license": "ISC",
  "dependencies": {
    "@sindresorhus/slugify": "^3.0.0",
    "cli-progress": "^3.12.0",
    "commander": "^15.0.0",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.5",
    "music-metadata": "^11.13.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@types/cli-progress": "^3.11.6",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3"
  }
}
